// NEW: Authentication & Appointment System
      let isAuthenticated = false;
      let isSignupMode = false;
      let currentUser = null;

      // Demo credentials
      const demoUsers = { 'test@hotel.com': '123456' };

      // 1. LOGIN SYSTEM
      document.getElementById('loginForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const email = document.getElementById('loginEmail').value;
        const password = document.getElementById('loginPassword').value;

        if (isSignupMode) {
          // Create account
          localStorage.setItem(email, password);
          alert('✅ Account created! Please sign in.');
          toggleLoginMode();
          return;
        }

        // Login validation
        if (demoUsers[email] === password || localStorage.getItem(email) === password) {
          isAuthenticated = true;
          currentUser = email;
          document.getElementById('loginOverlay').style.display = 'none';
          
          // Smooth entrance for main content
          document.body.style.opacity = '0';
          document.body.style.transition = 'opacity 0.5s ease';
          setTimeout(() => {
            document.body.style.opacity = '1';
          }, 100);
        } else {
          alert('❌ Invalid credentials!\nDemo: test@hotel.com / 123456');
        }
      });

      // Toggle login/signup
      document.getElementById('switchMode').addEventListener('click', toggleLoginMode);
      function toggleLoginMode() {
        isSignupMode = !isSignupMode;
        const title = document.getElementById('loginTitle');
        const switchText = document.getElementById('switchMode');
        
        if (isSignupMode) {
          title.textContent = 'Create Account';
          switchText.textContent = 'I have an account';
        } else {
          title.textContent = 'Welcome to Hotel Miranda';
          switchText.textContent = 'Create New Account';
        }
      }

      // 2. APPOINTMENT SYSTEM
      function openAppointmentModal() {
        if (!isAuthenticated) {
          alert('⚠️ Please login first!');
          return false;
        }
        document.getElementById('appointmentModal').style.display = 'flex';
      }

      // Close appointment modal
      document.getElementById('closeModal').onclick = function() {
        document.getElementById('appointmentModal').style.display = 'none';
      };

      // Appointment form submission
      document.getElementById('appointmentForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const appointment = {
          name: document.getElementById('appName').value,
          phone: document.getElementById('appPhone').value,
          date: document.getElementById('appDate').value,
          time: document.getElementById('appTime').value,
          notes: document.getElementById('appNotes').value,
          user: currentUser,
          timestamp: new Date().toISOString()
        };

        // Save appointment (localStorage - ready for backend)
        const appointments = JSON.parse(localStorage.getItem('appointments') || '[]');
        appointments.push(appointment);
        localStorage.setItem('appointments', JSON.stringify(appointments));

        // Show success
        document.getElementById('successAlert').style.display = 'block';
        document.getElementById('appointmentForm').style.display = 'none';
        
        // Reset after 3 seconds
        setTimeout(() => {
          document.getElementById('appointmentModal').style.display = 'none';
          document.getElementById('appointmentForm').style.display = 'block';
          document.getElementById('successAlert').style.display = 'none';
          document.getElementById('appointmentForm').reset();
        }, 3000);
      });

      // Close modals on outside click
      document.querySelectorAll('.login-overlay, .appointment-modal').forEach(modal => {
        modal.addEventListener('click', function(e) {
          if (e.target === this) this.style.display = 'none';
        });
      });

      // Block access if not logged in (keyboard/mouse)
      document.addEventListener('keydown', function(e) {
        if (!isAuthenticated && e.key === 'Escape') e.preventDefault();
      });

const menuBtn = document.getElementById("menu-btn");
const navLinks = document.getElementById("nav-links");
const menuBtnIcon = menuBtn.querySelector("i");

menuBtn.addEventListener("click", (e) => {
  navLinks.classList.toggle("open");

  const isOpen = navLinks.classList.contains("open");
  menuBtnIcon.setAttribute("class", isOpen ? "ri-close-line" : "ri-menu-line");
});

navLinks.addEventListener("click", (e) => {
  navLinks.classList.remove("open");
  menuBtnIcon.setAttribute("class", "ri-menu-line");
});

const scrollRevealOption = {
  distance: "50px",
  origin: "bottom",
  duration: 1000,
};

// header container
ScrollReveal().reveal(".header__container .section__subheader", {
  ...scrollRevealOption,
});

ScrollReveal().reveal(".header__container h1", {
  ...scrollRevealOption,
  delay: 500,
});

ScrollReveal().reveal(".header__container .btn", {
  ...scrollRevealOption,
  delay: 1000,
});

// room container
ScrollReveal().reveal(".room__card", {
  ...scrollRevealOption,
  interval: 500,
});

// feature container
ScrollReveal().reveal(".feature__card", {
  ...scrollRevealOption,
  interval: 500,
});

// news container
ScrollReveal().reveal(".news__card", {
  ...scrollRevealOption,
  interval: 500,
});
