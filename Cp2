
import json
import os
from datetime import datetime
import csv

DATA_FILE = "students.json"
CSV_FILE = "students_export.csv"

class StudentManager:
    def __init__(self):
        self.students = self.load_data()
    
    def load_data(self):
        """Load students from JSON file"""
        if os.path.exists(DATA_FILE):
            try:
                with open(DATA_FILE, 'r') as f:
                    return json.load(f)
            except (json.JSONDecodeError, IOError) as e:
                print(f"Warning: Could not load data file: {e}")
                return []
        return []
    
    def save_data(self):
        """Save students to JSON file"""
        try:
            with open(DATA_FILE, 'w') as f:
                json.dump(self.students, f, indent=2)
            return True
        except IOError as e:
            print(f"Error saving data: {e}")
            return False
    
    def validate_id(self, student_id):
        """Validate student ID format (e.g., 2026-001)"""
        if not student_id:
            return False
        if len(student_id) < 5:
            return False
        return True
    
    def validate_year(self, year):
        """Validate year level (1-5)"""
        try:
            return 1 <= int(year) <= 5
        except ValueError:
            return False
    
    def get_input(self, prompt, validator=None):
        """Get validated input from user"""
        while True:
            value = input(prompt).strip()
            if not validator or validator(value):
                return value
            print("Invalid input! Please try again.")
    
    def add_student(self):
        """Add new student with validation"""
        print("\n" + "="*40)
        print("           ADD NEW STUDENT")
        print("="*40)
        
        student_id = self.get_input("Enter Student ID (e.g., 2026-001): ", self.validate_id)
        
        # Check for duplicate ID
        if any(s["id"] == student_id for s in self.students):
            print("Student ID already exists!")
            return
        
        name = self.get_input("Enter Full Name: ")
        course = self.get_input("Enter Course: ")
        year = self.get_input("Enter Year Level (1-5): ", self.validate_year)
        
        student = {
            "id": student_id,
            "name": name.title(),
            "course": course.title(),
            "year": year,
            "created_at": datetime.now().isoformat()
        }
        
        self.students.append(student)
        if self.save_data():
            print(f"Student '{name}' added successfully!")
    
    def view_students(self):
        """Display all students with improved formatting"""
        if not self.students:
            print("\nNo students found in the system.")
            return
        
        print("\n" + "="*70)
        print("                       STUDENT LIST")
        print("="*70)
        print(f"{'ID':<12} {'Name':<25} {'Course':<20} {'Year':<6} {'Created':<20}")
        print("-" * 70)
        
        for s in self.students:
            created = datetime.fromisoformat(s["created_at"]).strftime("%Y-%m-%d")
            print(f"{s['id']:<12}{s['name']:<25}{s['course']:<20}{s['year']:<6}{created:<20}")
    
    def search_student(self):
        """Search student by ID or name"""
        print("\nSEARCH STUDENT")
        search_term = input("Enter Student ID or Name: ").lower().strip()
        
        found_students = [
            s for s in self.students 
            if search_term in s["id"].lower() or search_term in s["name"].lower()
        ]
        
        if not found_students:
            print("No students found matching your search.")
            return
        
        print(f"\nFound {len(found_students)} student(s):")
        print("-" * 50)
        for s in found_students:
            print(f"ID: {s['id']} | Name: {s['name']} | Course: {s['course']} | Year: {s['year']}")
    
    def update_student(self):
        """Update student information"""
        if not self.students:
            print("\nNo students to update.")
            return
        
        student_id = self.get_input("Enter Student ID to update: ", self.validate_id)
        student = next((s for s in self.students if s["id"] == student_id), None)
        
        if not student:
            print("Student not found.")
            return
        
        print(f"\nCurrent details for {student['name']}:")
        print(f"Name: {student['name']}")
        print(f"Course: {student['course']}")
        print(f"Year: {student['year']}")
        
        print("\nEnter new details (press Enter to keep current):")
        new_name = input(f"New Name [{student['name']}]: ").strip() or student['name']
        new_course = input(f"New Course [{student['course']}]: ").strip() or student['course']
        new_year = self.get_input(f"New Year [{student['year']}]: ", self.validate_year)
        
        student["name"] = new_name.title()
        student["course"] = new_course.title()
        student["year"] = new_year
        student["created_at"] = datetime.now().isoformat()
        
        if self.save_data():
            print("Student information updated successfully!")
    
    def delete_student(self):
        """Delete student with confirmation"""
        if not self.students:
            print("\nNo students to delete.")
            return
        
        student_id = self.get_input("Enter Student ID to delete: ", self.validate_id)
        student = next((s for s in self.students if s["id"] == student_id), None)
        
        if not student:
            print("Student not found.")
            return
        
        print(f"\nDelete student: {student['name']}?")
        print(f"   Course: {student['course']} | Year: {student['year']}")
        
        confirm = input("Are you sure? (y/N): ").lower().strip()
        if confirm == 'y':
            self.students.remove(student)
            if self.save_data():
                print("Student deleted successfully!")
        else:
            print("Deletion cancelled.")
    
    def show_statistics(self):
        """Display system statistics"""
        total = len(self.students)
        if total == 0:
            print("\nSTATISTICS\nNo students in the system.")
            return
        
        years = {}
        courses = {}
        for s in self.students:
            years[s['year']] = years.get(s['year'], 0) + 1
            courses[s['course']] = courses.get(s['course'], 0) + 1
        
        print("\n" + "="*50)
        print("                   SYSTEM STATISTICS")
        print("="*50)
        print(f"Total Students: {total}")
        print(f"Average per Year: {total/len(years):.1f}")
        print("\nBy Year Level:")
        for year, count in sorted(years.items()):
            print(f"  Year {year}: {count} students")
        print("\nTop Courses:")
        for course, count in sorted(courses.items(), key=lambda x: x[1], reverse=True)[:3]:
            print(f"  {course}: {count} students")
    
    def export_csv(self):
        """Export students to CSV file"""
        if not self.students:
            print("\nNo students to export.")
            return
        
        try:
            with open(CSV_FILE, 'w', newline='', encoding='utf-8') as f:
                writer = csv.DictWriter(f, fieldnames=['id', 'name', 'course', 'year'])
                writer.writeheader()
                writer.writerows(self.students)
            print(f"Data exported to {CSV_FILE}")
        except IOError as e:
            print(f"Export failed: {e}")
    
    def sort_students(self):
        """Sort students by different criteria"""
        if not self.students:
            print("\nNo students to sort.")
            return
        
        print("\nSort by:")
        print("1. ID")
        print("2. Name")
        print("3. Course")
        print("4. Year")
        
        choice = input("Enter choice (1-4): ").strip()
        if choice == "1":
            self.students.sort(key=lambda x: x['id'])
        elif choice == "2":
            self.students.sort(key=lambda x: x['name'])
        elif choice == "3":
            self.students.sort(key=lambda x: x['course'])
        elif choice == "4":
            self.students.sort(key=lambda x: int(x['year']))
        else:
            print("Invalid choice!")
            return
        
        print("Students sorted!")
        self.view_students()


def show_menu():
    """Display enhanced menu"""
    print("\n" + "="*50)
    print("      STUDENT MANAGEMENT SYSTEM v2.0")
    print("="*50)
    print("1. Add New Student")
    print("2. View All Students")
    print("3. Search Student")
    print("4. Update Student")
    print("5. Delete Student")
    print("6. Show Statistics")
    print("7. Export to CSV")
    print("8. Sort Students")
    print("9. Exit")
    print("-" * 50)


def main():
    """Main program"""
    manager = StudentManager()
    
    while True:
        show_menu()
        choice = input("Enter your choice (1-9): ").strip()
        
        if choice == "1":
            manager.add_student()
        elif choice == "2":
            manager.view_students()
        elif choice == "3":
            manager.search_student()
        elif choice == "4":
            manager.update_student()
        elif choice == "5":
            manager.delete_student()
        elif choice == "6":
            manager.show_statistics()
        elif choice == "7":
            manager.export_csv()
        elif choice == "8":
            manager.sort_students()
        elif choice == "9":
            print("\nThank you for using Student Management System!")
            print("All data automatically saved.")
            break
        else:
            print("Invalid choice! Please enter 1-9.")
        
        input("\nPress Enter to continue...")


if __name__ == "__main__":
    main()
